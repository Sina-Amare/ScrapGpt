# ==============================================================================
# ScrapGPT Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ==============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Application name displayed in API docs
APP_NAME=ScrapGPT

# Environment: development, staging, production
ENVIRONMENT=development

# Enable debug mode (disable in production!)
DEBUG=true

# API version prefix
API_V1_PREFIX=/api/v1

# -----------------------------------------------------------------------------
# Server Settings
# -----------------------------------------------------------------------------
# Host to bind the server to (use 0.0.0.0 for Docker)
HOST=127.0.0.1

# Port to run the server on
PORT=8000

# Number of worker processes (for production with Gunicorn)
WORKERS=1

# -----------------------------------------------------------------------------
# Database Settings
# -----------------------------------------------------------------------------
# PostgreSQL connection URL
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/scrapegpt

# Connection pool settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# -----------------------------------------------------------------------------
# Security & Authentication
# -----------------------------------------------------------------------------
# Secret key for JWT token signing (generate with: openssl rand -hex 32)
SECRET_KEY=your-super-secret-key-change-this-in-production

# JWT token settings
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password hashing settings
PASSWORD_HASH_ROUNDS=12

# -----------------------------------------------------------------------------
# CORS Settings
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins (use * for development only)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Provider API key encryption.
# Generate a value with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Back up this value separately from your database. Losing it makes all stored
# provider API keys permanently unrecoverable.
PROVIDER_KEY_ENCRYPTION_SECRET=replace-with-generated-fernet-key

# -----------------------------------------------------------------------------
# Scraping Settings
# -----------------------------------------------------------------------------
# Request timeout in seconds
SCRAPE_TIMEOUT=30

# Self-hosted resource controls
MAX_CONCURRENT_JOBS_PER_USER=3
MAX_PAGES_PER_JOB=500
CRAWL_CONCURRENCY=3
MIN_CRAWL_DELAY_MS=500
JOB_QUEUE_DEPTH=10

# User agent for scraping requests
USER_AGENT=ScrapGPT/1.0 (+https://github.com/yourusername/scrapegpt)

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json, text
LOG_FORMAT=text
